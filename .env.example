# Django Settings
SECRET_KEY=your-super-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,web

# Database
DATABASE_URL=postgresql://concert_user:concert_pass@db:5432/concert_db
DB_NAME=concert_db
DB_USER=concert_user
DB_PASSWORD=concert_pass
DB_HOST=db
DB_PORT=5432

# Encryption
ENCRYPTION_KEY=your-encryption-key-32-chars-here

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-password

# Redis (if needed)
REDIS_URL=redis://redis:6379/0

# Company Info
COMPANY_NAME=Concert Company
COMPANY_ADDRESS=Your Address Here
